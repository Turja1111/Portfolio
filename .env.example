# ── Environment ──────────────────────────────────────────────────
DEBUG=False
SECRET_KEY=change_me_to_a_long_random_string_at_least_50_chars
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@db:5432/portfolio_db
POSTGRES_DB=portfolio_db
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Email (optional) ──────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your_app_password
