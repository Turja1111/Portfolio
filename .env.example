# Environment
DEBUG=True
SECRET_KEY=change_me_to_a_long_random_string_at_least_50_chars
ALLOWED_HOSTS=localhost 127.0.0.1

# Database
DB_NAME=Portfolio
DB_USER=postgres
DB_PASSWORD=Admin
DB_HOST=localhost
DB_PORT=5432

# Email (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your_app_password

# Chatbot (DeepSeek)
DEEPSEEK_API_KEY=your_rotated_deepseek_api_key
